{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.py"
    },
    {
      "source": "/priority-access",
      "destination": "/index.html"
    },
    {
      "source": "/confirmation",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "functions": {
    "backend/server.py": {
      "runtime": "vercel-python@3.9"
    }
  }
}
